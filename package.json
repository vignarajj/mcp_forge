{
  "name": "@vignaraj_rr/mcp-forge",
  "version": "1.0.0",
  "type": "module",
  "description": "A lightweight, purely local macOS desktop application for creating, editing, managing, and switching between MCP (Model Context Protocol) profiles.",
  "author": "vignaraj",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/vignaraj/mcp-forge.git"
  },
  "homepage": "https://github.com/vignaraj/mcp-forge#readme",
  "bugs": {
    "url": "https://github.com/vignaraj/mcp-forge/issues"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "profile-manager",
    "cursor",
    "claude-code",
    "codex",
    "gemini-cli",
    "ai-tools"
  ],
  "bin": {
    "mcp-forge": "./bin/cli.js"
  },
  "files": [
    "bin/",
    "dist/",
    "src/",
    "index.html",
    "package.json",
    "vite.config.ts",
    "tsconfig.json",
    "README.md"
  ],
  "scripts": {
    "dev": "vite --port=3000 --host=0.0.0.0",
    "build": "vite build",
    "preview": "vite preview",
    "clean": "rm -rf dist",
    "lint": "tsc --noEmit",
    "test": "vitest run",
    "coverage": "vitest run --coverage",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.1.14",
    "@vitejs/plugin-react": "^5.0.4",
    "clsx": "^2.1.1",
    "lucide-react": "^0.546.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "vite": "^6.2.0"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^22.14.0",
    "@vitest/coverage-v8": "^4.1.0",
    "fake-indexeddb": "^6.2.5",
    "jsdom": "^29.0.1",
    "tailwindcss": "^4.1.14",
    "typescript": "~5.8.2",
    "vite": "^6.2.0",
    "vitest": "^4.1.0"
  }
}
